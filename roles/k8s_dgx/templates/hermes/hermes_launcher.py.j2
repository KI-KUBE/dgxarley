#!/opt/hermes/.venv/bin/python3
"""Wrapper that disables the dashboard's localhost-only WS guard.

The /api/ws, /api/pty, /api/events handlers in hermes_cli.web_server reject
WebSocket upgrades whose `ws.client.host` is not in `_LOOPBACK_HOSTS`
(closes with code 4403 → HTTP 403). This is a defence for the standalone
`hermes dashboard --tui` mode where the upstream is exposed directly to a
browser on localhost; it makes a reverse-proxy setup impossible because
the proxy's client IP (from Hermes' perspective) won't match the loopback
allow-list reliably.

We sit behind Caddy + caddy-security in the same pod which already
terminates auth via an HMAC-JWT cookie, so the dashboard's loopback check
is redundant in our deployment. Replace the frozenset with a sentinel that
always returns True for `in` so the WS handlers fall through to the real
session-token check (which IS robust — `_SESSION_TOKEN` is generated per
process start with `secrets.token_urlsafe(32)` and embedded into the
served HTML for the JS bundle to read).
"""
import sys


class _AlwaysIn:
    """`x in _AlwaysIn()` always returns True."""

    def __contains__(self, _item):
        return True


import hermes_cli.web_server as _ws  # noqa: E402

# Confirmed via in-pod probe: with `hermes dashboard --host 0.0.0.0` the
# WebSocket-upgrade `ws.client.host` is the POD IP (e.g. 10.68.0.140), not
# 127.0.0.1, even when Caddy connects via 127.0.0.1:9119 from the same
# pod. The kernel binds the listening socket on 0.0.0.0 to the default-
# route interface so accepted connections look like they come from the
# pod's eth0 address. _LOOPBACK_HOSTS therefore never matches in any
# Kubernetes-style deployment and the patch is mandatory regardless of
# whether the proxy lives in the same pod, the same node, or elsewhere.
_ws._LOOPBACK_HOSTS = _AlwaysIn()

from hermes_cli.main import main  # noqa: E402

sys.exit(main())
