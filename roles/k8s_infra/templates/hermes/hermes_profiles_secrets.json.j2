{# Secret per-profile env-var map, keyed by profile name, consumed by
   hermes_merge_config.py. These KEY=VALUE pairs are folded into
   /opt/data/profiles/<name>/.env; the profile .env ALSO inherits the default
   profile's .env (so OPENAI_API_KEY / litellm_token is present for the vision aux).
   Only profiles that bring their own model key (a `provider:` block) appear with a key. #}
{
{% for p in item.profiles | default([]) %}
{% set prov = p.provider | default({}) %}
{% set _san = p.name | upper | regex_replace('[^A-Z0-9]', '_') %}
  {{ p.name | to_json }}: {% if prov.get('api_key') %}{ "PROFILE_{{ _san }}_MODEL_API_KEY": {{ prov.api_key | to_json }} }{% else %}{}{% endif %}{{ "," if not loop.last else "" }}
{% endfor %}
}
